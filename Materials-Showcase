  button{font-family:inherit;font-size:13.5px;font-weight:600;border:1.5px solid var(--line);background:#fff;color:var(--navy);padding:7px 13px;border-radius:8px;cursor:pointer;}
  button:hover{border-color:var(--steel);} button.pri{background:var(--navy);color:#fff;border-color:var(--navy);}
  #which{margin-left:6px;font-size:12px;color:var(--mut);}
  #cvwrap{flex:1;min-height:0;position:relative;}
  canvas{display:block;width:100%;height:100%;}
  #pay{padding:9px 20px;background:#fff;border-top:1px solid var(--line);font-size:13.5px;color:var(--navy);font-weight:600;line-height:1.4;}
  #pay b{color:var(--terra);}
</style>
</head>
<body>
<div id="app">
  <header>
    <h1>The property table is one bonding physics, seen four ways</h1>
    <p>Each column is a readout of the energy well or the electrons &middot; ENGR 170</p>
  </header>
  <div id="bar">
    <button id="prev">‚Äπ Prev</button>
    <button class="pri" id="next">Next connection ‚Ä∫</button>
    <button id="all">Show all</button>
    <button id="reset">‚Ü∫ Reset</button>
    <span id="which">0 / 4</span>
  </div>
  <div id="cvwrap"><canvas id="cv"></canvas></div>
  <div id="pay"></div>
</div>
<script>
const cv=document.getElementById('cv'),ctx=cv.getContext('2d');
const K={navy:"#1F3864",steel:"#2E5496",terra:"#B85042",teal:"#1F7A63",amber:"#E8890C",gold:"#F2B705",
  ink:"#21262E",mut:"#6B7480",line:"#C7CFDA",white:"#fff",bg:"#F1F4F8"};
let W,Hc,dpr,t=0;
let shown=0;                       // number of connectors shown (0..4); 4 = all
const COLS=["Bond","Melting T","Modulus E","Conductivity","Ductility"];
const ROWS=[
 ["Ionic","high","high","insulator","brittle"],
 ["Covalent","very high","very high","insulator","brittle"],
 ["Metallic","mod‚Äìhigh","mod‚Äìhigh","conductor","ductile"]];
// connector meta: source visual, target column index, color, label
const CONN=[
 {col:1,color:K.terra,label:"well depth D ‚Üí melting T",short:"depth D",src:"depth"},
 {col:2,color:K.teal, label:"curvature 2Da¬≤ ‚Üí modulus E",short:"curvature 2Da¬≤",src:"curv"},
 {col:3,color:K.amber,label:"electron mobility ‚Üí conductivity",short:"e‚Åª mobility",src:"elec"},
 {col:4,color:K.steel,label:"shear response ‚Üí ductility",short:"shear response",src:"shear"}];
const PAY='Two columns read off the <b>shape of the well</b> (depth‚ÜíT<sub>m</sub>, curvature‚ÜíE); two read off <b>what the electrons do</b> (mobility‚Üíconductivity, shear response‚Üíductility). The whole table is one bonding physics, seen four ways.';
function resize(){dpr=Math.min(devicePixelRatio,2);cv.width=cv.clientWidth*dpr;cv.height=cv.clientHeight*dpr;W=cv.width;Hc=cv.height;}
window.addEventListener('resize',resize);
function txt(s,x,y,col,sz,al,bold,serif){ctx.fillStyle=col;ctx.font=(bold?'bold ':'')+(sz*dpr)+'px '+(serif?'Cambria,serif':'Calibri,sans-serif');ctx.textAlign=al||'left';ctx.textBaseline='middle';ctx.fillText(s,x,y);}
function rrect(x,y,w,h,r,fill,stroke,lw){ctx.beginPath();ctx.moveTo(x+r,y);ctx.arcTo(x+w,y,x+w,y+h,r);ctx.arcTo(x+w,y+h,x,y+h,r);ctx.arcTo(x,y+h,x,y,r);ctx.arcTo(x,y,x+w,y,r);ctx.closePath();if(fill){ctx.fillStyle=fill;ctx.fill();}if(stroke){ctx.strokeStyle=stroke;ctx.lineWidth=(lw||1)*dpr;ctx.stroke();}}

// ----- table geometry -----
let TB;
function tableGeom(){
  const x0=24*dpr, y0=132*dpr, tw=W*0.50-24*dpr, rh=(Hc-y0-40*dpr)/4;
  const cwv=[0.20,0.20,0.20,0.20,0.20]; let cw=cwv.map(v=>v*tw);
  const xs=[]; let cx=x0; for(let i=0;i<5;i++){xs.push(cx);cx+=cw[i];}
  return {x0,y0,tw,rh:Math.min(rh,72*dpr),cw,xs,h:0.55*Math.min(rh,72*dpr)};
}
function colCenter(ci){const g=TB;return g.xs[ci]+g.cw[ci]/2;}
function drawTable(){
  const g=TB; const hh=48*dpr;
  // header
  let cx=g.x0;
  for(let i=0;i<5;i++){ const active=(shown>0 && CONN.slice(0,shown).some(c=>c.col===i));
    rrect(g.xs[i]+1*dpr,g.y0,g.cw[i]-2*dpr,hh,4*dpr, active?colOf(i):K.navy, null);
    txt(COLS[i],g.xs[i]+g.cw[i]/2,g.y0+hh/2,K.white,12.5,'center',true);
    cx+=g.cw[i]; }
  // rows
  for(let r=0;r<3;r++){ const ry=g.y0+hh+r*(g.rh);
    for(let i=0;i<5;i++){ const active=(shown>0 && CONN.slice(0,shown).some(c=>c.col===i));
      rrect(g.xs[i]+1*dpr,ry+1*dpr,g.cw[i]-2*dpr,g.rh-2*dpr,3*dpr, active&&i>0? tint(i):(r%2?K.bg:K.white), K.line,0.8);
      const v=ROWS[r][i];
      txt(v,g.xs[i]+g.cw[i]/2,ry+g.rh/2, i===0?K.navy:(active&&i>0?colOf(i):K.ink), i===0?13:12, 'center', i===0);
    }
  }
}
function colOf(ci){const c=CONN.find(c=>c.col===ci);return c?c.color:K.navy;}
function tint(ci){const c=CONN.find(c=>c.col===ci);if(!c)return K.white;
  const map={ "#B85042":"#FBE7E2","#1F7A63":"#E1F1EB","#E8890C":"#FBEBD5","#2E5496":"#E3ECF7"};return map[c.color]||K.white;}

// ----- right visuals -----
function wellBox(){ return {x:W*0.55, y:96*dpr, w:W*0.42, h:(Hc-140*dpr)*0.44}; }
function elecBox(){ const wb=wellBox(); return {x:wb.x, y:wb.y+wb.h+22*dpr, w:wb.w*0.52, h:(Hc-140*dpr)*0.40}; }
function shearBox(){ const wb=wellBox(),eb=elecBox(); return {x:eb.x+eb.w+16*dpr, y:eb.y, w:wb.w-eb.w-16*dpr, h:eb.h}; }

let Danim=4.6, Aanim=18;
function morse(r,D,a){const e=Math.exp(-a*(r-0.28));return D*(1-e)*(1-e)-D;}
function drawWell(){
  const b=wellBox(); rrect(b.x,b.y,b.w,b.h,10*dpr,K.white,K.line,1.2);
  txt("interatomic energy well  U(r)",b.x+b.w/2,b.y+16*dpr,K.navy,12,'center',true);
  const pl=b.x+40*dpr, pr=b.x+b.w-20*dpr, pt=b.y+30*dpr, pb=b.y+b.h-26*dpr;
  const D=Danim,a=Aanim, Umin=-(D+0.4);
  const X=r=>pl+(r-0.20)/(0.55-0.20)*(pr-pl), Y=u=>pt+(0.6-u)/(0.6-Umin)*(pb-pt);
  // zero line
  ctx.setLineDash([4*dpr,3*dpr]);ctx.beginPath();ctx.moveTo(pl,Y(0));ctx.lineTo(pr,Y(0));ctx.strokeStyle=K.line;ctx.lineWidth=1*dpr;ctx.stroke();ctx.setLineDash([]);
  // curve
  ctx.beginPath();let st=false;for(let px=pl;px<=pr;px++){const r=0.20+(px-pl)/(pr-pl)*0.35;let u=morse(r,D,a);if(u>0.6){st=false;continue;}const y=Y(u);if(!st){ctx.moveTo(px,y);st=true;}else ctx.lineTo(px,y);}
  ctx.strokeStyle=K.steel;ctx.lineWidth=3*dpr;ctx.lineJoin='round';ctx.stroke();
  // r0 dashed + depth bracket
  const xr=X(0.28), ymin=Y(-D);
  ctx.setLineDash([5*dpr,3*dpr]);ctx.beginPath();ctx.moveTo(xr,pt);ctx.lineTo(xr,ymin);ctx.strokeStyle=K.navy;ctx.lineWidth=1.2*dpr;ctx.stroke();ctx.setLineDash([]);
  txt("r‚ÇÄ",xr,pt-2*dpr,K.navy,11,'center',true);
  // depth marker
  const active1=shown>=1;
  ctx.strokeStyle=active1?K.terra:K.mut;ctx.lineWidth=2*dpr;ctx.beginPath();ctx.moveTo(pl+6*dpr,Y(0));ctx.lineTo(pl+6*dpr,ymin);ctx.stroke();
  txt("D",pl+13*dpr,(Y(0)+ymin)/2,active1?K.terra:K.mut,12,'left',true);
  // curvature marker (a small arc hugging the bottom)
  const active2=shown>=2;
  ctx.strokeStyle=active2?K.teal:K.mut;ctx.lineWidth=2.4*dpr;ctx.beginPath();
  for(let px=xr-26*dpr;px<=xr+26*dpr;px+=2){const r=0.20+(px-pl)/(pr-pl)*0.35;ctx.lineTo(px,Y(morse(r,D,a)));}ctx.stroke();
  if(active2)txt("U‚Ä≥(r‚ÇÄ)=2Da¬≤ = "+Math.round(2*D*a*a).toLocaleString(),xr,ymin+16*dpr,K.teal,10.5,'center',true);
  // anchors for connectors
  wellDepthAnchor=[pl+6*dpr,(Y(0)+ymin)/2]; wellCurvAnchor=[xr,ymin];
}
let wellDepthAnchor=[0,0],wellCurvAnchor=[0,0],elecAnchor=[0,0],shearAnchor=[0,0];

let seaE=[]; function initSea(b){seaE=[];for(let i=0;i<16;i++)seaE.push({x:b.x+20*dpr+Math.random()*(b.w-40*dpr),y:b.y+40*dpr+Math.random()*(b.h-60*dpr),vx:(Math.random()-.5)*.4*dpr,vy:(Math.random()-.5)*.4*dpr});}
function drawElec(){
  const b=elecBox(); rrect(b.x,b.y,b.w,b.h,10*dpr,K.white,K.line,1.2);
  txt("what the electrons do",b.x+b.w/2,b.y+15*dpr,K.navy,11.5,'center',true);
  const active3=shown>=3;
  // localized (left half)
  const lh={x:b.x+8*dpr,y:b.y+26*dpr,w:b.w/2-12*dpr,h:b.h-58*dpr};
  txt("localized",lh.x+lh.w/2,b.y+b.h-14*dpr,K.mut,9.5,'center',true);
  for(let i=0;i<2;i++)for(let j=0;j<2;j++){const cx=lh.x+lh.w*(0.3+0.4*i),cy=lh.y+lh.h*(0.3+0.4*j);
    ctx.beginPath();ctx.arc(cx,cy,7*dpr,0,7);ctx.fillStyle=K.steel;ctx.fill();
    ctx.beginPath();ctx.arc(cx+9*dpr,cy,2.4*dpr,0,7);ctx.fillStyle=K.teal;ctx.fill();}
  // sea (right half)
  const sh={x:b.x+b.w/2+4*dpr,y:b.y+26*dpr,w:b.w/2-12*dpr,h:b.h-58*dpr};
  txt("delocalized sea",sh.x+sh.w/2,b.y+b.h-14*dpr,K.mut,9.5,'center',true);
  if(!seaE.length||seaE[0].x<sh.x-5*dpr||seaE[0].x>sh.x+sh.w+5*dpr)initSea(sh);
  for(let i=0;i<2;i++)for(let j=0;j<2;j++){const cx=sh.x+sh.w*(0.3+0.4*i),cy=sh.y+sh.h*(0.3+0.4*j);
    ctx.beginPath();ctx.arc(cx,cy,7*dpr,0,7);ctx.fillStyle=K.navy;ctx.fill();txt("+",cx,cy,K.white,9,'center',true);}
  for(const e of seaE){ctx.beginPath();ctx.arc(e.x,e.y,2.3*dpr,0,7);ctx.fillStyle=K.teal;ctx.fill();}
  // field arrow when active
  if(active3){ const ay=b.y+b.h+2*dpr; // draw inside bottom
    txt("apply field  E ‚Üí",b.x+b.w/2,b.y+b.h-1*dpr,K.amber,9.5,'center',true);
  }
  elecAnchor=[b.x+b.w-6*dpr,b.y+b.h*0.5];
}
function planeAtoms(px,py,pw,ph,kind){ // draw a row of 3 atoms inside a plane
  const ys=py+ph/2;
  for(let i=0;i<3;i++){ const x=px+pw*(0.25+0.25*i);
    let col=K.navy; if(kind==="ionic") col=(i%2? K.amber:K.steel); else if(kind==="cov") col="#5A6472"; else col=K.navy;
    ctx.beginPath();ctx.arc(x,ys,Math.min(ph*0.32,pw*0.11),0,7);ctx.fillStyle=col;ctx.fill();
  }
}
function drawShear(){
  const b=shearBox(); rrect(b.x,b.y,b.w,b.h,10*dpr,K.white,K.line,1.2);
  txt("shear outcome",b.x+b.w/2,b.y+15*dpr,K.navy,11.5,'center',true);
  const active4=shown>=4; const off=active4?12*dpr:0;
  const items=[["Ionic",K.terra,"cleaves","ionic"],["Covalent",K.steel,"snaps","cov"],["Metallic",K.teal,"holds","met"]];
  const iw=(b.w-14*dpr)/3;
  items.forEach((it,k)=>{ const bx=b.x+7*dpr+k*iw, gw=iw-9*dpr, gx=bx+4*dpr;
    const gy=b.y+34*dpr, gh=b.h-72*dpr, ph=gh*0.42;
    const gap=(active4 && k<2)? 9*dpr : 3*dpr;
    // top plane (offset when active) + bottom plane
    rrect(gx+off, gy, gw, ph, 3*dpr, K.bg, it[1],1.3); planeAtoms(gx+off,gy,gw,ph,it[3]);
    rrect(gx, gy+ph+gap, gw, ph, 3*dpr, K.bg, it[1],1.3); planeAtoms(gx,gy+ph+gap,gw,ph,it[3]);
    if(active4 && k<2){ // crack/snap between the planes
      ctx.strokeStyle=K.terra;ctx.lineWidth=2.6*dpr;ctx.setLineDash([4*dpr,3*dpr]);
      ctx.beginPath();ctx.moveTo(gx,gy+ph+gap/2);ctx.lineTo(gx+gw+off,gy+ph+gap/2);ctx.stroke();ctx.setLineDash([]); }
    if(active4 && k===2){ // metallic: intact contact line (no gap), teal
      ctx.strokeStyle=K.teal;ctx.lineWidth=2*dpr;ctx.beginPath();ctx.moveTo(gx,gy+ph+gap/2);ctx.lineTo(gx+gw+off,gy+ph+gap/2);ctx.stroke(); }
    txt(it[0],bx+iw/2,gy+2*ph+gap+16*dpr,it[1],10.5,'center',true);
    txt(active4?it[2]:"‚Äî",bx+iw/2,gy+2*ph+gap+30*dpr,active4?it[1]:K.mut,10,'center',active4);
  });
  shearAnchor=[b.x+b.w-6*dpr,b.y+b.h*0.5];
}
// ----- connectors -----
function connector(c,anchor,alpha){
  const cx0=colCenter(c.col), cy0=TB.y0-4*dpr;
  ctx.globalAlpha=alpha; ctx.strokeStyle=c.color; ctx.lineWidth=2.4*dpr;
  ctx.beginPath();ctx.moveTo(anchor[0],anchor[1]);
  const mx=(anchor[0]+cx0)/2;
  ctx.bezierCurveTo(mx,anchor[1], mx,cy0-30*dpr, cx0,cy0);
  ctx.stroke();
  // arrowhead into column
  ctx.beginPath();ctx.moveTo(cx0,cy0);ctx.lineTo(cx0-5*dpr,cy0-9*dpr);ctx.lineTo(cx0+5*dpr,cy0-9*dpr);ctx.closePath();ctx.fillStyle=c.color;ctx.fill();
  // label chip in the lane ABOVE the target column header (clear of header text)
  const lx=cx0, ly=TB.y0-20*dpr;
  ctx.font='bold '+(11*dpr)+'px Calibri'; const wLab=ctx.measureText(c.short).width+14*dpr;
  rrect(lx-wLab/2,ly-11*dpr,wLab,22*dpr,6*dpr,"#fff",c.color,1.5);
  txt(c.short,lx,ly,c.color,11,'center',true);
  ctx.globalAlpha=1;
}
function srcAnchor(src){return src==="depth"?wellDepthAnchor:src==="curv"?wellCurvAnchor:src==="elec"?elecAnchor:shearAnchor;}

function draw(){
  ctx.clearRect(0,0,W,Hc); TB=tableGeom();
  drawTable(); drawWell(); drawElec(); drawShear();
  for(let i=0;i<shown;i++){ connector(CONN[i], srcAnchor(CONN[i].src), 1); }
  document.getElementById('which').textContent=shown+" / 4";
  document.getElementById('pay').innerHTML = shown>=4 ? PAY :
    (shown===0?'Step through the four connections, or ‚ÄúShow all‚Äù.':CONN[shown-1].label.replace(/‚Üí/g,'‚Üí')+'  ‚Äî  '+
      ["","deeper well ‚Üí more thermal energy to separate atoms ‚Üí higher melting T.",
       "sharper well (larger 2Da¬≤) ‚Üí stiffer bond ‚Üí larger elastic modulus E.",
       "delocalized electron sea drifts in a field ‚Üí conducts; localized electrons can‚Äôt ‚Üí insulates.",
       "ionic cleaves & covalent snaps (brittle); metallic sea lets cores slide (ductile)."][shown]);
}
function tick(){ t+=0.016;
  if(shown>=1){ Danim=4.6+ (shown===1? 1.6*Math.sin(t*1.6):0); }  else Danim=4.6;
  if(shown>=2){ Aanim=18 + (shown===2? 7*Math.sin(t*1.5):0); } else Aanim=18;
  // sea drift (accelerate in field when step3 active)
  const sh=shearBox(); const eb=elecBox(); const shb={x:eb.x+eb.w/2+4*dpr};
  for(const e of seaE){ const bias=(shown>=3)?0.35*dpr:0; e.x+=e.vx+bias; e.y+=e.vy;
    const lx=eb.x+eb.w/2+4*dpr, rx=eb.x+eb.w-8*dpr, ty=eb.y+26*dpr, by=eb.y+eb.h-32*dpr;
    if(e.x<lx){e.x=rx;} if(e.x>rx){e.x=lx;} if(e.y<ty||e.y>by)e.vy*=-1;
    if(Math.random()<0.02){e.vx=(Math.random()-.5)*.4*dpr;e.vy=(Math.random()-.5)*.4*dpr;} }
  draw(); requestAnimationFrame(tick);
}
document.getElementById('next').onclick=()=>{shown=Math.min(4,shown+1);};
document.getElementById('prev').onclick=()=>{shown=Math.max(0,shown-1);};
document.getElementById('all').onclick=()=>{shown=4;};
document.getElementById('reset').onclick=()=>{shown=0;};
resize(); requestAnimationFrame(tick);
</script>
</body>
